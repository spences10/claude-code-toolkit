{
  "description": "Secret safety hooks powered by nopeek CLI. SessionStart loads credentials, PreToolUse redacts cloud CLI output.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-load.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/redact-output.sh"
          }
        ]
      }
    ]
  }
}
